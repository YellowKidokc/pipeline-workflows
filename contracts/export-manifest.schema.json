{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faiththruphysics.com/schemas/export-manifest.schema.json",
  "title": "FORGE Export Manifest",
  "type": "object",
  "required": ["name", "status", "source_map", "created_at"],
  "properties": {
    "name": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["active", "ready", "published", "archived"]
    },
    "series_total": { "type": "integer", "minimum": 0 },
    "series_ready": { "type": "integer", "minimum": 0 },
    "source_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "copied_to"],
        "properties": {
          "source": { "type": "string" },
          "copied_to": { "type": "string" },
          "hash": { "type": "string" },
          "purpose": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "cleanup_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason", "approved"],
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" },
          "approved": { "type": "boolean" }
        }
      }
    },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
