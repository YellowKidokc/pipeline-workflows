{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StationConfig",
  "description": "I/O contract for a pipeline station. Points to code on X:\\Backside, not in this repo.",
  "type": "object",
  "required": ["name", "path", "type", "status", "input", "output"],
  "properties": {
    "name": { "type": "string", "description": "Station identifier matching STATION_REGISTRY key" },
    "version": { "type": "string", "default": "1.0" },
    "path": { "type": "string", "description": "Absolute path to station folder on X:\\Backside" },
    "type": { "enum": ["local", "remote"], "description": "local = X: drive, remote = NAS/network" },
    "has_run_bat": { "type": "boolean" },
    "status": { "enum": ["active", "review", "fail", "planned", "deprecated"] },
    "input": {
      "type": "object",
      "required": ["accepts", "source"],
      "properties": {
        "accepts": { "type": "array", "items": { "type": "string" }, "description": "File extensions: md, html, txt, pdf, json, etc." },
        "source": { "type": "string", "default": "INPUT/" },
        "description": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["produces", "destination"],
      "properties": {
        "produces": { "type": "array", "items": { "type": "string" } },
        "destination": { "type": "string", "default": "OUTPUT/" },
        "schema": { "type": "string", "description": "Output format name for downstream validation" },
        "description": { "type": "string" }
      }
    },
    "llm_checkpoint": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "engine": { "type": ["string", "null"], "description": "ollama:phi4, ollama:llama3, etc." },
        "prompt": { "type": ["string", "null"], "description": "Gate prompt text or path to .md prompt file" }
      }
    },
    "dependencies": { "type": "array", "items": { "type": "string" }, "default": [] },
    "idempotency": {
      "type": "object",
      "properties": {
        "method": { "enum": ["input_hash", "filename", "none"], "default": "input_hash" },
        "cache": { "type": "string", "default": "ARCHIVE/" }
      }
    },
    "canary": {
      "type": "object",
      "properties": {
        "last_run": { "type": ["string", "null"] },
        "result": { "enum": ["pass", "review", "fail", "untested"] },
        "kind": { "type": "string", "description": "Canary test type: usage, self-test, schema, etc." }
      }
    }
  }
}