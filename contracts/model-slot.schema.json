{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faiththruphysics.com/schemas/model-slot.schema.json",
  "title": "FORGE Model Slot",
  "type": "object",
  "required": ["slot", "name", "library", "status", "category", "path"],
  "properties": {
    "slot": { "type": "integer", "minimum": 1 },
    "name": { "type": "string" },
    "library": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["active", "installed", "placeholder", "empty", "degraded", "retired"]
    },
    "category": {
      "type": "string",
      "enum": ["nlp", "preference", "vision", "audio", "graph", "other"]
    },
    "path": { "type": "string" },
    "old_name": { "type": "string" },
    "notes": { "type": "string" },
    "feeds_into": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fed_by": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fallback": { "type": "string" },
    "station_users": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
