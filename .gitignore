# Transitional export artifacts — keep contracts, not bulky builds
exports/active/*
exports/ready/*
exports/published/*
exports/archived/*
exports/_manifest/*.jsonl
!exports/active/.gitkeep
!exports/ready/.gitkeep
!exports/published/.gitkeep
!exports/archived/.gitkeep
!exports/_manifest/README.md
!exports/_manifest/export-manifest.schema.json

# Runtime state — regenerated by orchestrator
STATUS.json
MANIFEST.json
logs/corrections/*.jsonl
*.log

# Local machine config — commit pipeline.config.example.json instead
pipeline.config.json

# Model weight formats — never in repo
*.safetensors

