!**/REVIEW/.gitkeep
!**/ARCHIVE/.gitkeep
!**/ERROR/.gitkeep
!**/LOGS/.gitkeep

# Runtime state — regenerated by orchestrator
STATUS.json
MANIFEST.json
logs/corrections/*.jsonl

# Caches and build products
