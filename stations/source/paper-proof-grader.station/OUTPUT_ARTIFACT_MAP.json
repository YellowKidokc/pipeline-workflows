{
  "schema_version": "0.1",
  "purpose": "Machine-readable target map for paper-proof-grader outputs and station ownership.",
  "canonical_root": "X:\\paper-proof-grader",
  "families": [
    {
      "id": "provenance",
      "required": true,
      "formats": ["json", "sha256", "md"],
      "primary_audience": ["machine", "auditor"],
      "station_ids": ["00", "13"],
      "artifacts": ["source-manifest.json", "source.sha256", "run-manifest.json", "run-summary.md"]
    },
    {
      "id": "normalized_source",
      "required": true,
      "formats": ["md", "json"],
      "primary_audience": ["claim extractor", "reviewer"],
      "station_ids": ["01", "02"],
      "artifacts": ["normalized-text.md", "structure-map.json"]
    },
    {
      "id": "claim_ledger",
      "required": true,
      "formats": ["csv", "xlsx", "json"],
      "primary_audience": ["reviewer", "machine"],
      "station_ids": ["03", "04", "05", "06", "07", "08", "09", "10"],
      "artifacts": ["claim-ledger.csv", "paper-grade.json", "reviewer-workbook.xlsx"]
    },
    {
      "id": "formalization",
      "required": true,
      "formats": ["json", "md", "xlsx"],
      "primary_audience": ["Lean partner", "proof reviewer"],
      "station_ids": ["08"],
      "artifacts": ["formal-target-map.json", "formal-target-map.md", "reviewer-workbook.xlsx#Formal_Targets"]
    },
    {
      "id": "objections",
      "required": true,
      "formats": ["md", "csv", "xlsx"],
      "primary_audience": ["adversarial reviewer", "editor"],
      "station_ids": ["09"],
      "artifacts": ["objection-ledger.md", "reviewer-workbook.xlsx#Objections"]
    },
    {
      "id": "human_reports",
      "required": true,
      "formats": ["md", "html", "xlsx"],
      "primary_audience": ["David", "institution", "public reviewer"],
      "station_ids": ["11"],
      "artifacts": ["paper-grade.md", "paper-grade.html", "reviewer-workbook.xlsx"]
    },
    {
      "id": "vector_index",
      "required": false,
      "formats": ["jsonl", "md"],
      "primary_audience": ["Brain search", "AI partners"],
      "station_ids": ["12"],
      "artifacts": ["vector-summary.jsonl"]
    }
  ],
  "required_workbook_sheets": [
    "Dashboard",
    "Source_Manifest",
    "Claim_Index",
    "Structure_Map",
    "Evidence_Ledger",
    "7Q_Forward",
    "7Q_Reverse",
    "Formal_Targets",
    "Objections",
    "Constraint_Matrix",
    "Global_Metrics",
    "Claim_Total_Score",
    "Readiness_Decision",
    "Output_Manifest"
  ],
  "optional_workbook_sheets": [
    "Theory_Mapping",
    "Domain_Mapping",
    "XDTI_Score",
    "Constraint_Density",
    "Directional_Asymmetry",
    "Coverage_Analysis",
    "Comparative_Analysis"
  ],
  "readiness_gate_required_fields": [
    "claim_uuid",
    "source_span",
    "claim_type",
    "evidence_required",
    "support_status",
    "kill_condition",
    "overclaim_risk",
    "category_error_risk",
    "formal_route_or_boundary"
  ],
  "build_order": [
    "source-manifest.json",
    "run-manifest.json",
    "normalized-text.md",
    "source spans in claim rows",
    "claim-ledger.csv",
    "reviewer workbook skeleton",
    "evidence ledger",
    "7Q forward/reverse sheets",
    "formal target map",
    "objection ledger",
    "readiness decision",
    "static HTML portal",
    "vector summaries"
  ]
}
