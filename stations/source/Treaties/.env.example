# ── Treaties Environment ──
# Copy this to .env and adjust for your setup.

# ═══════════════════════════════════════════════════════════
# Postgres
# ═══════════════════════════════════════════════════════════
# Local development (Postgres running on your machine):
DATABASE_URL=postgresql+psycopg://treaties:treaties@localhost:5432/treaties

# Docker (Postgres in docker-compose):
# DATABASE_URL=postgresql+psycopg://treaties:treaties@postgres:5432/treaties

# ═══════════════════════════════════════════════════════════
# Ollama (local LLM)
# ═══════════════════════════════════════════════════════════
# Local Ollama (running on your machine, NOT in Docker):
OLLAMA_BASE_URL=http://localhost:11434

# Docker on Windows/Mac (Ollama on host machine):
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Docker with Ollama in compose (docker-compose.full.yml):
# OLLAMA_BASE_URL=http://ollama:11434

OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=180

# ═══════════════════════════════════════════════════════════
# App
# ═══════════════════════════════════════════════════════════
APP_HOST=127.0.0.1
APP_PORT=8000
SNAPSHOT_DIR=./snapshots
