{
  "manifest_version": 3,
  "name": "BIL Passive Preference Signals",
  "version": "0.1.0",
  "description": "Collects passive browser preference signals for the local BIL endpoint.",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:8420/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
