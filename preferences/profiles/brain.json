{
  "profile": "brain",
  "inherits": "default",
  "output_style": {
    "summary": "handoff_first_then_index_later",
    "format": "markdown",
    "tts_friendly": true
  },
  "run_behavior": {
    "dry_run": true,
    "preserve_originals": true,
    "stop_for_review_on_quality_fail": true,
    "continue_to_route_on_ready": false
  },
  "routing": {
    "default_destination": "vault_drop"
  }
}
